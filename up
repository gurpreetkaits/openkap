#!/bin/bash

# Start the ScreenBuddy development environment

echo "Starting ScreenBuddy..."

# Clean start
docker compose down 2>/dev/null
docker ps -aq --filter "name=openkap" | xargs -r docker rm -f 2>/dev/null

# Build and start (healthchecks handle readiness)
docker compose up -d --build --wait

echo ""
echo "ScreenBuddy is ready"
echo ""
echo "Services:"
echo "  Frontend: http://localhost:${FRONTEND_PORT:-3333}"
echo "  Backend:  http://localhost:${APP_PORT:-8888}"
echo "  Database: localhost:${DOCKER_DB_PORT:-13306}"
echo "  Redis:    localhost:${DOCKER_REDIS_PORT:-16379}"
echo ""
echo "Memory usage:"
docker stats --no-stream --format "  {{.Name}}: {{.MemUsage}}" 2>/dev/null
echo ""
echo "Logs:  docker compose logs -f"
echo "Stop:  ./down"
