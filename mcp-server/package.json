{
  "name": "openkap-mcp",
  "version": "1.0.0",
  "description": "MCP server for OpenKap — talk to video transcriptions, summaries, and comments from Claude or any AI tool",
  "type": "module",
  "bin": {
    "openkap-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "openkap",
    "transcription",
    "video",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
