[mysqld]
# === Dev-optimized: minimal memory footprint ===

# InnoDB buffer pool -- 64MB is plenty for dev
innodb_buffer_pool_size = 64M
innodb_log_buffer_size = 4M

# Minimal per-connection buffers
sort_buffer_size = 128K
read_buffer_size = 128K
read_rnd_buffer_size = 256K
join_buffer_size = 128K
tmp_table_size = 8M
max_heap_table_size = 8M

# Few connections needed for solo dev
max_connections = 10

# === Performance ===
skip-name-resolve
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1

# Query cache disabled -- Laravel uses Redis
query_cache_type = 0
query_cache_size = 0

# Slow query log
slow_query_log = 1
long_query_time = 2
